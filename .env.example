# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
APP_DB_PASSWORD=changeme
KEYCLOAK_DB_PASSWORD=changeme

# ------------------------------------------------------------
# KEYCLOAK — ADMIN BOOTSTRAP
# Temporary admin used to access the Keycloak console on first startup.
# ------------------------------------------------------------
KEYCLOAK_ADMIN_PASSWORD=changeme

# ------------------------------------------------------------
# KEYCLOAK — RESOURCE SERVER CLIENT
# Client ID and secret of the 'resource-server' Keycloak client.
# Used by the backend for token exchange and token introspection.
# Value: Keycloak console → Clients → resource-server → Credentials
#        or keycloak/realm-export.json → clients[resource-server].secret
# ------------------------------------------------------------
KEYCLOAK_RESOURCE_CLIENT_ID=resource-server
KEYCLOAK_RESOURCE_CLIENT_SECRET=changeme

# ------------------------------------------------------------
# KEYCLOAK — GOOGLE IDENTITY PROVIDER
# OAuth2 credentials from Google Cloud Console.
# Injected into realm-export.json at import time to auto-configure the Google IdP.
# Steps: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
#        Authorized redirect URI: http://localhost:8080/realms/spring-boot-template/broker/google/endpoint
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# ------------------------------------------------------------
# APP — SECURITY MODE
# Options: API_KEY | KEYCLOAK_OPAQUE | KEYCLOAK_JWT
# ------------------------------------------------------------
APP_SECURITY_MODE=KEYCLOAK_JWT
