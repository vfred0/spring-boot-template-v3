###############################################################################
# RBAC MANAGEMENT (KEYCLOAK_JWT mode) — two-actor walkthrough
# (IntelliJ HTTP Client / VS Code REST Client)
#
# TWO ACTORS, run top-to-bottom:
#   [ADMIN]    The pre-seeded Keycloak admin (admin/admin).
#              Already bound to the ADMIN role via docker-compose devseed.
#   [NEW USER] A freshly registered user with no role yet.
#              Admin will assign them DATA_ANALYST at the end.
#
# PREREQUISITE:
#   docker compose --profile keycloak up -d
#   docker compose up -d spring-boot-template   (APP_SECURITY_MODE=KEYCLOAK_JWT default)
#
# TWO RBAC SYSTEMS — do not confuse them:
#   Keycloak realm roles  -> ROLE_* authorities only (Spring Security)
#   App DB RBAC (this)    -> resource:action permissions, read on EVERY request
#                            from identity.user_roles by keycloak `sub`
###############################################################################

###############################################################################
# PART 1 — ADMIN: login and confirm access
###############################################################################

### 1. LOGIN as admin — pre-seeded with ADMIN role via devseed
# @name adminLogin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{adminPassword}}",
  "clientId": "{{clientId}}",
  "clientSecret": "{{clientSecret}}"
}

> {%
    client.test("admin login 200", () =>
        client.assert(response.status === 200, `Got ${response.status}`));
    client.global.set("adminToken", response.body.data.access_token);
%}

### 2. WHOAMI (admin) — verify ADMIN role and rbac:manage authority
GET {{baseUrl}}/api/me
Authorization: Bearer {{adminToken}}

> {%
    client.test("admin has ADMIN role", () =>
        client.assert(response.body.data.role === "ADMIN",
            `role=${response.body.data.role} — is the devseed running? (SPRING_FLYWAY_LOCATIONS must include classpath:db/devseed)`));
    client.global.set("adminSub", response.body.data.subject);
    client.log("Admin sub = " + response.body.data.subject);
%}

###############################################################################
# BOOTSTRAP GATE (dev: already done by devseed — skip to step 3)
#
# In production (no devseed), the first admin must be granted via SQL:
#
#   1. Create the ADMIN role with rbac:manage + apikeys:manage:
#        docker compose exec -T spring-boot-template-db \
#          psql -U spring-boot-template -d spring-boot-template \
#          < src/main/resources/db/seed/rbac_admin_role.sql
#
#   2. Bind a subject to ADMIN (get the sub from step 2 above):
#        docker compose exec -T spring-boot-template-db \
#          psql -U spring-boot-template -d spring-boot-template \
#          -v subject=<PASTE-SUB-HERE> \
#          < src/main/resources/db/seed/bind_admin.sql
#
# No re-login needed — authorities are read from the DB on every request.
###############################################################################

### 3. LIST ROLES — confirms rbac:manage works (403 = bootstrap pending)
GET {{baseUrl}}/api/rbac/roles
Authorization: Bearer {{adminToken}}

> {%
    client.test("admin can list roles", () =>
        client.assert(response.status === 200,
            `Got ${response.status} — run the BOOTSTRAP GATE above`));
%}

###############################################################################
# PART 2 — NEW USER: register and capture subject
###############################################################################

### 4. REGISTER new user — 409 on re-run (user already exists)
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "username": "{{registerUsername}}",
  "password": "{{registerPassword}}",
  "names": "Victor Arreaga"
}

> {%
    client.test("user registered (or 409 on re-run)", () =>
        client.assert(response.status === 201 || response.status === 409,
            `Got ${response.status}`));
%}

### 5. LOGIN as new user
# @name userLogin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{registerUsername}}",
  "password": "{{registerPassword}}",
  "clientId": "{{clientId}}",
  "clientSecret": "{{clientSecret}}"
}

> {%
    client.test("user login 200", () =>
        client.assert(response.status === 200, `Got ${response.status}`));
    client.global.set("userToken", response.body.data.access_token);
%}

### 6. WHOAMI (new user) — no role yet, capture their keycloak sub
GET {{baseUrl}}/api/me
Authorization: Bearer {{userToken}}

> {%
    client.test("user has no role yet", () =>
        client.assert(response.status === 200, `Got ${response.status}`));
    client.test("role is null before assignment", () =>
        client.assert(response.body.data.role === null,
            `Expected null, got ${response.body.data.role}`));
    client.global.set("userSub", response.body.data.subject);
    client.log("New user sub = " + response.body.data.subject);
%}

###############################################################################
# PART 3 — ADMIN: build a role and assign it to the new user
###############################################################################

### 7. CREATE PERMISSION — adds resource:action to the catalog
POST {{baseUrl}}/api/rbac/permissions
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{ "resource": "customers", "action": "read" }

> {%
    client.test("permission present (201 or 409)", () =>
        client.assert(response.status === 201 || response.status === 409,
            `Got ${response.status}`));
%}

### 8. CREATE ROLE DATA_ANALYST
# @name createRole
POST {{baseUrl}}/api/rbac/roles
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "DATA_ANALYST",
  "description": "Read customer data"
}

> {%
    client.test("role present (201 or 409)", () =>
        client.assert(response.status === 201 || response.status === 409,
            `Got ${response.status}`));
    if (response.status === 201) {
        client.global.set("roleId", response.body.data.id);
    }
%}

### 9. RESOLVE roleId — needed if step 8 returned 409 (role already existed)
GET {{baseUrl}}/api/rbac/roles
Authorization: Bearer {{adminToken}}

> {%
    client.test("roles listed", () =>
        client.assert(response.status === 200, `Got ${response.status}`));
    const role = response.body.data.find(r => r.name === "DATA_ANALYST");
    if (role) client.global.set("roleId", role.id);
    client.log("roleId = " + client.global.get("roleId"));
%}

### 10. ATTACH PERMISSIONS to DATA_ANALYST (additive, keeps existing)
POST {{baseUrl}}/api/rbac/roles/{{roleId}}/permissions
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "permissions": [
    { "resource": "customers", "action": "read" }
  ]
}

> {%
    client.test("permissions attached", () =>
        client.assert(response.status === 200, `Got ${response.status}`));
    client.test("role has customers:read", () =>
        client.assert(response.body.data.permissions.includes("customers:read"),
            JSON.stringify(response.body.data.permissions)));
%}

### 11. ASSIGN DATA_ANALYST to the new user
PUT {{baseUrl}}/api/rbac/users/{{userSub}}/role
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{ "role": "DATA_ANALYST" }

> {%
    client.test("role assigned to user", () =>
        client.assert(response.status === 200, `Got ${response.status}`));
    client.log("Assigned DATA_ANALYST to sub=" + client.global.get("userSub"));
%}

###############################################################################
# PART 4 — NEW USER: verify the assignment (no re-login needed)
###############################################################################

### 12. WHOAMI (new user) — same token, role now reflects DB change
GET {{baseUrl}}/api/me
Authorization: Bearer {{userToken}}

> {%
    client.test("user now has DATA_ANALYST", () =>
        client.assert(response.body.data.role === "DATA_ANALYST",
            `role=${response.body.data.role}`));
    client.test("user has customers:read authority", () =>
        client.assert(response.body.data.authorities.includes("customers:read"),
            JSON.stringify(response.body.data.authorities)));
%}

###############################################################################
# PART 5 — CLEANUP (optional)
###############################################################################

### 13. UNASSIGN role from the new user
DELETE {{baseUrl}}/api/rbac/users/{{userSub}}/role
Authorization: Bearer {{adminToken}}

> {%
    client.test("role unassigned (204)", () =>
        client.assert(response.status === 204, `Got ${response.status}`));
%}

### 14. DELETE role — 409 if any subject is still assigned
DELETE {{baseUrl}}/api/rbac/roles/{{roleId}}
Authorization: Bearer {{adminToken}}

> {%
    client.test("role deleted (204)", () =>
        client.assert(response.status === 204, `Got ${response.status}`));
%}

### 15. (NEGATIVE) NO TOKEN — protected endpoint must reject
GET {{baseUrl}}/api/rbac/roles

> {%
    client.test("missing token -> 401", () =>
        client.assert(response.status === 401, `Got ${response.status}`));
%}
